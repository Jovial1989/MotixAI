# Flutter dart-define environment variables
# Copy this file and pass each key via --dart-define=KEY=value on the flutter CLI.
# Do NOT commit real production values — use CI secrets or a local untracked file.

# ─────────────────────────────────────────────────────────────────────────────
# API_BASE_URL
#   The root URL of the MotixAI backend.
#
#   • Production (Supabase Edge Functions):
#       https://<your-project-ref>.supabase.co/functions/v1/api
#
#   • Local NestJS dev server:
#       iOS simulator  → http://localhost:4000/api/v1
#       Android emul.  → http://10.0.2.2:4000/api/v1
#       Physical device → http://192.168.x.x:4000/api/v1
# ─────────────────────────────────────────────────────────────────────────────
API_BASE_URL=https://<your-project-ref>.supabase.co/functions/v1/api
