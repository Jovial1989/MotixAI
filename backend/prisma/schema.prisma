generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ENTERPRISE_ADMIN
}

enum JobType {
  GUIDE_IMAGE_GENERATION
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  manuals   ManualDocument[]
  guides    RepairGuide[]
  vehicles  Vehicle[]
  parts     Part[]
  repairJobs    RepairJob[]
  guideRequests GuideRequest[]
}

enum GuideStatus {
  pending
  generating
  ready
  failed
}

enum GuideDifficulty {
  easy
  medium
  hard
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  fullName         String
  role             Role     @default(USER)
  refreshTokenHash String?
  tenantId         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  guides RepairGuide[]
  repairJobs   RepairJob[]
  guideRequests GuideRequest[]
}

model Vehicle {
  id           String   @id @default(cuid())
  tenantId     String?
  vin          String?
  model        String
  manufacturer String?
  year         Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  guides RepairGuide[]
  manuals ManualDocument[]
  repairJobs RepairJob[]

  @@index([tenantId, model])
}

model Part {
  id         String   @id @default(cuid())
  tenantId   String?
  name       String
  oemNumber  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  guides RepairGuide[]

  @@index([tenantId, name])
}

model RepairGuide {
  id             String   @id @default(cuid())
  tenantId       String?
  userId         String
  vehicleId      String
  partId         String
  manualId       String?
  title          String
  difficulty     String
  timeEstimate   String
  safetyNotes    String[]
  tools          String[]
  inputVin       String?
  inputModel     String?
  inputPart      String
  sourceType     String   @default("B2C")
  status         String   @default("READY")
  searchKeywords   String[]
  popularity       Int      @default(0)
  source           String   @default("generated")
  confidence       Int?
  taskType         String?
  sourceProvider   String?
  sourceReferences Json?
  createdAt        DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id])
  tenant  Tenant?        @relation(fields: [tenantId], references: [id])
  vehicle Vehicle        @relation(fields: [vehicleId], references: [id])
  part    Part           @relation(fields: [partId], references: [id])
  manual  ManualDocument? @relation(fields: [manualId], references: [id])
  steps         RepairStep[]
  images        GeneratedImage[]
  jobs          Job[]
  repairJobs    RepairJob[]
  guideRequests GuideRequest[]

  @@index([tenantId, userId, createdAt])
}

model RepairStep {
  id           String   @id @default(cuid())
  guideId      String
  stepOrder    Int
  title        String
  instruction  String
  torqueValue  String?
  warningNote  String?
  imageStatus  String   @default("none")   // none | queued | searching_refs | analyzing_refs | generating | ready | failed
  imageUrl     String?
  imagePrompt  String?
  imageError   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  guide RepairGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId, stepOrder])
}

model RepairJob {
  id                   String   @id @default(cuid())
  tenantId             String?
  userId               String
  vehicleId            String
  guideId              String?
  assignedTechnicianId String?
  problemDescription   String
  status               String   @default("pending")   // pending | in_progress | completed
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id])
  tenant  Tenant?      @relation(fields: [tenantId], references: [id])
  vehicle Vehicle      @relation(fields: [vehicleId], references: [id])
  guide   RepairGuide? @relation(fields: [guideId], references: [id])

  @@index([tenantId, userId, createdAt])
  @@index([vehicleId])
}

model GuideRequest {
  id           String   @id @default(cuid())
  tenantId     String?
  userId       String
  vehicleModel String
  repairType   String
  partNumber   String?
  notes        String?
  status       String   @default("pending")   // pending | processing | completed | rejected
  guideId      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id])
  tenant  Tenant?      @relation(fields: [tenantId], references: [id])
  guide   RepairGuide? @relation(fields: [guideId], references: [id])

  @@index([tenantId, status, createdAt])
}

model GeneratedImage {
  id          String   @id @default(cuid())
  guideId      String
  stepOrder    Int
  prompt       String
  imageUrl     String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  guide RepairGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId, stepOrder])
}

model ManualDocument {
  id             String   @id @default(cuid())
  tenantId       String
  title          String
  fileUrl        String
  extractedText  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id])
  vehicles Vehicle[]
  guides   RepairGuide[]
}

model Job {
  id          String    @id @default(cuid())
  guideId      String
  type         JobType
  status       JobStatus @default(PENDING)
  payload      Json
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  guide RepairGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId, status])
}
