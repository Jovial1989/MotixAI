generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  user
  enterprise_admin
  admin
}

enum GuideStatus {
  pending
  generating
  ready
  failed
}

enum GuideDifficulty {
  easy
  medium
  hard
}

// ─── Enterprise ───────────────────────────────────────────────────────────────

model Enterprise {
  id        String         @id @default(uuid())
  name      String
  slug      String         @unique
  users     User[]
  manuals   Manual[]
  vehicles  VehicleModel[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("enterprises")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String          @id @default(uuid())
  email        String          @unique
  name         String
  passwordHash String
  role         UserRole        @default(user)
  enterpriseId String?
  enterprise   Enterprise?     @relation(fields: [enterpriseId], references: [id])
  guides       RepairGuide[]
  favorites    Favorite[]
  history      SearchHistory[]
  refreshToken String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@map("users")
}

// ─── Vehicle ──────────────────────────────────────────────────────────────────

model VehicleModel {
  id           String        @id @default(uuid())
  make         String
  model        String
  year         Int?
  vin          String?       @unique
  enterpriseId String?
  enterprise   Enterprise?   @relation(fields: [enterpriseId], references: [id])
  guides       RepairGuide[]
  createdAt    DateTime      @default(now())

  @@index([make, model])
  @@map("vehicle_models")
}

// ─── Part ─────────────────────────────────────────────────────────────────────

model Part {
  id        String        @id @default(uuid())
  name      String
  oemNumber String?
  category  String?
  guides    RepairGuide[]
  createdAt DateTime      @default(now())

  @@index([oemNumber])
  @@map("parts")
}

// ─── Repair Guide ─────────────────────────────────────────────────────────────

model RepairGuide {
  id            String           @id @default(uuid())
  title         String
  status        GuideStatus      @default(pending)
  difficulty    GuideDifficulty?
  estimatedTime String?
  safetyNotes   String[]
  tools         String[]
  materials     String[]
  images        String[]
  oemSummary    String?
  errorMessage  String?
  vehicleId     String
  vehicle       VehicleModel     @relation(fields: [vehicleId], references: [id])
  partId        String
  part          Part             @relation(fields: [partId], references: [id])
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  steps         GuideStep[]
  favorites     Favorite[]
  historyItems  SearchHistory[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId])
  @@index([vehicleId, partId])
  @@map("repair_guides")
}

model GuideStep {
  id          String      @id @default(uuid())
  stepNumber  Int
  title       String
  description String      @db.Text
  imageUrl    String?
  warning     String?
  guideId     String
  guide       RepairGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId])
  @@map("guide_steps")
}

// ─── Favorites ────────────────────────────────────────────────────────────────

model Favorite {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  guideId   String
  guide     RepairGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, guideId])
  @@map("favorites")
}

// ─── Search History ───────────────────────────────────────────────────────────

model SearchHistory {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String
  guideId   String?
  guide     RepairGuide? @relation(fields: [guideId], references: [id], onDelete: SetNull)
  createdAt DateTime     @default(now())

  @@index([userId])
  @@map("search_history")
}

// ─── Enterprise Manuals ───────────────────────────────────────────────────────

model Manual {
  id           String     @id @default(uuid())
  title        String
  fileName     String
  fileUrl      String
  vehicleModel String?
  indexed      Boolean    @default(false)
  enterpriseId String
  enterprise   Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([enterpriseId])
  @@map("manuals")
}
