{
  "name": "hammerai",
  "version": "1.0.0",
  "private": true,
  "description": "HammerAI – monorepo for Web, Mobile and Backend",
  "workspaces": [
    "packages/shared",
    "backend",
    "web",
    "mobile"
  ],
  "scripts": {
    "dev:backend": "yarn workspace @hammerai/backend dev",
    "dev:web": "yarn workspace @hammerai/web dev",
    "dev:mobile": "yarn workspace @hammerai/mobile start",
    "dev:mobile:ios": "yarn workspace @hammerai/mobile ios",
    "build:backend": "yarn workspace @hammerai/backend build",
    "build:web": "yarn workspace @hammerai/web build",
    "build": "yarn build:backend && yarn build:web",
    "lint": "yarn workspaces run lint",
    "test": "yarn workspaces run test",
    "typecheck": "yarn workspaces run typecheck"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=1.22.0"
  }
}
